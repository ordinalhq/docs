{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ordinal Docs",
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:site_name": "Ordinal Docs",
      "robots": "index, follow"
    }
  },
  "colors": {
    "primary": "#24574D",
    "light": "#8EF5B5",
    "dark": "#24574D"
  },
  "favicon": "/ordinal-favicon.svg",
  "fonts": {
    "family": "Inter"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "icon": "grid-2",
          "href": "https://app.tryordinal.com"
        },
        {
          "anchor": "Support",
          "icon": "headset",
          "href": "mailto:support@tryordinal.com"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "star",
            "pages": [
              "getting-started/overview",
              "getting-started/quickstart",
              "getting-started/concepts"
            ]
          },
          {
            "group": "Social Profiles",
            "icon": "circle-user",
            "pages": [
              "social-profiles/overview",
              "social-profiles/linkedin",
              "social-profiles/twitter",
              "social-profiles/instagram",
              "social-profiles/threads",
              "social-profiles/facebook",
              "social-profiles/tiktok",
              "social-profiles/youtube-shorts",
              "social-profiles/webflow",
              "social-profiles/slack",
              "social-profiles/discord"
            ]
          },
          {
            "group": "Calendar and Posts",
            "icon": "calendar",
            "pages": [
              "calendar/overview",
              {
                "group": "Posts",
                "icon": "file-lines",
                "pages": [
                  "posts/overview",
                  "posts/creating-posts",
                  "posts/drafting-posts",
                  "posts/scheduling-posts",
                  "posts/trash",
                  "posts/media",
                  "posts/ai-writing",
                  "posts/cross-posting",
                  "posts/post-defaults",
                  "posts/version-history"
                ]
              },
              "campaigns/overview",
              "posts/auto-engagements",
              "posts/slack-boost",
              "posts/ideas",
              "posts/labels",
              "posts/statuses"
            ]
          },
          {
            "group": "Collaboration and Approvals",
            "icon": "circle-check",
            "pages": [
              "collaboration/approvals",
              "collaboration/commenting",
              "collaboration/notifications",
              "collaboration/team-permissions"
            ]
          },
          {
            "group": "Analytics and Reporting",
            "icon": "chart-line",
            "pages": [
              "analytics/overview",
              "analytics/shortlinks"
            ]
          },
          {
            "group": "Account and Billing",
            "icon": "user",
            "pages": [
              "account/user-preferences",
              "account/subscription-plans"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "pages": [
              "integrations/slack",
              "integrations/dub"
            ]
          },
          {
            "group": "Affiliate and Referrals",
            "icon": "gift",
            "pages": [
              "referrals/affiliate",
              "referrals/referral"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Overview",
            "icon": "book",
            "pages": [
              "api/introduction",
              "api/authentication",
              "api/file-uploads",
              "api/linkedin-mentions",
              "api/errors"
            ]
          },
          {
            "group": "Endpoints",
            "icon": "code",
            "openapi": "api/openapi.json"
          }
        ]
      },
      {
        "tab": "MCP",
        "groups": [
          {
            "group": "Overview",
            "icon": "server",
            "pages": [
              "mcp/introduction",
              "mcp/install/overview",
              "mcp/tools",
              "mcp/migrating"
            ]
          }
        ]
      },
      {
        "tab": "Webhooks",
        "groups": [
          {
            "group": "Overview",
            "icon": "webhook",
            "pages": [
              "integrations/webhooks/introduction",
              "integrations/webhooks/event-types"
            ]
          },
          {
            "group": "Social Profile",
            "icon": "circle-user",
            "pages": [
              "integrations/webhooks/social-profile-connected",
              "integrations/webhooks/social-profile-disconnected",
              "integrations/webhooks/social-profile-reconnect-needed"
            ]
          },
          {
            "group": "Posts",
            "icon": "file-lines",
            "pages": [
              "integrations/webhooks/post-created",
              "integrations/webhooks/post-scheduled",
              "integrations/webhooks/post-rescheduled",
              "integrations/webhooks/post-unscheduled",
              "integrations/webhooks/post-published",
              "integrations/webhooks/post-publish-failed",
              "integrations/webhooks/post-archived",
              "integrations/webhooks/post-permanently-deleted",
              "integrations/webhooks/post-content-edited",
              "integrations/webhooks/post-comment-created",
              "integrations/webhooks/post-inline-comment-created"
            ]
          },
          {
            "group": "Approvals",
            "icon": "circle-check",
            "pages": [
              "integrations/webhooks/post-approval-requested",
              "integrations/webhooks/post-approval-approved",
              "integrations/webhooks/campaign-approval-requested",
              "integrations/webhooks/campaign-approval-approved"
            ]
          },
          {
            "group": "Invites",
            "icon": "user-plus",
            "pages": [
              "integrations/webhooks/invite-created",
              "integrations/webhooks/invite-accepted"
            ]
          }
        ]
      },
      {
        "tab": "Agency API",
        "groups": [
          {
            "group": "Overview",
            "icon": "building",
            "pages": [
              "agency-api/introduction",
              "agency-api/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "icon": "code",
            "openapi": {
              "source": "agency-api/openapi.json",
              "directory": "agency-api-reference"
            }
          }
        ]
      },
      {
        "tab": "Help Center",
        "hidden": true,
        "pages": [
          "help-center"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/ordinal-lightmode.svg",
    "dark": "/logo/ordinal-darkmode.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@tryordinal.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.tryordinal.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/tryordinal",
      "x": "https://x.com/tryordinal"
    }
  },
  "redirects": [
    {
      "source": "/api/mcp",
      "destination": "/mcp/introduction"
    },
    {
      "source": "/mcp/install/claude",
      "destination": "/mcp/install/overview"
    },
    {
      "source": "/mcp/install/claude-code",
      "destination": "/mcp/install/overview"
    },
    {
      "source": "/mcp/install/cursor",
      "destination": "/mcp/install/overview"
    },
    {
      "source": "/mcp/install/vscode",
      "destination": "/mcp/install/overview"
    }
  ]
}
